rules_version = '2';

// Security rules for the Settlement app. Deploy with:
//   firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Reads the referenced group doc (rule get()s bypass security rules).
    function groupData(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isGroupMember(groupId) {
      let g = groupData(groupId);
      return isSignedIn() &&
        (request.auth.uid == g.adminId || request.auth.uid in g.memberIds);
    }

    function isGroupAdmin(groupId) {
      return isSignedIn() && request.auth.uid == groupData(groupId).adminId;
    }

    function onlyChanges(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // Users — any signed-in user can read (friend/member lookups by
    // friendCode/email and display-name resolution rely on this). Owners may
    // write their whole profile; anyone else may amend ONLY the `friends` or
    // `groups` arrays (adding friends, joining/leaving groups).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId ||
        onlyChanges(['friends']) ||
        onlyChanges(['groups'])
      );
      allow delete: if false;
    }

    // Groups — readable by any signed-in user so a pending invitee can load the
    // group they're joining. Members update balances/expense ids and can leave;
    // a signed-in user may add ONLY themselves to memberIds (accepting invite).
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.adminId;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.adminId ||
        request.auth.uid in resource.data.memberIds ||
        (onlyChanges(['memberIds']) &&
          request.auth.uid in request.resource.data.memberIds)
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.adminId;
    }

    // Expenses — full access for the owner; group members may read a group
    // expense so it appears in the group's expense list.
    match /expenses/{expenseId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        (resource.data.groupId != null && isGroupMember(resource.data.groupId))
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.userId;
    }

    // Splits — only participants can see/modify a split (recording settlements).
    // A group admin may delete a split when deleting the group.
    match /splits/{splitId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.paidBy &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow delete: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        (resource.data.groupId != null && isGroupAdmin(resource.data.groupId))
      );
    }

    // Budgets — strictly private to the owner.
    match /budgets/{budgetId} {
      allow read, update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;
    }

    // Group invitations — visible to the sender and the invited email. The
    // invitee changes status (accept/decline); the sender can cancel.
    match /group_invitations/{invitationId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.invitedBy ||
        request.auth.token.email == resource.data.inviteeEmail
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.invitedBy;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.invitedBy ||
        request.auth.token.email == resource.data.inviteeEmail
      );
      allow delete: if isSignedIn() &&
        request.auth.uid == resource.data.invitedBy;
    }

    // Friend requests — visible to sender and recipient. The recipient
    // accepts/declines (status change); the sender can cancel (delete).
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.fromUserId ||
        request.auth.uid == resource.data.toUserId
      );
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.fromUserId &&
        request.auth.uid != request.resource.data.toUserId;
      allow update: if isSignedIn() &&
        request.auth.uid == resource.data.toUserId;
      allow delete: if isSignedIn() &&
        request.auth.uid == resource.data.fromUserId;
    }

    // Accounts — a user's payment accounts (cash, bank, card, wallet).
    // Strictly private to the owner.
    match /accounts/{accountId} {
      allow read, update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;
    }

    // Transfers — history of money moved between the owner's own accounts.
    // Immutable once written; strictly private to the owner.
    match /transfers/{transferId} {
      allow read, delete: if isSignedIn() &&
        request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;
      allow update: if false;
    }

    // Recurring transactions — the rules that materialise repeating expenses.
    // Strictly private to the owner.
    match /recurring_transactions/{ruleId} {
      allow read, update, delete: if isSignedIn() &&
        request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.userId;
    }

    // Deny everything else by default (e.g. the legacy top-level `settlements`
    // collection, which the app no longer writes).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
