<?xml version="1.0" encoding="utf-8"?>
<!--
    Budget widget (compact): header + up to 2 category progress rows. The wider
    responsive variant is widget_budget_expanded.xml (up to 4 rows). Rows use
    distinct ids (budget_0_*, budget_1_*) because RemoteViews actions address
    every view sharing an id, so repeated rows can't share ids.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_card"
    android:padding="@dimen/widget_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Budgets this month"
        android:textColor="@color/widget_text_muted"
        android:textSize="12sp"
        android:letterSpacing="0.05"
        android:textAllCaps="true" />

    <TextView
        android:id="@+id/budget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="No budgets set"
        android:textColor="@color/widget_text_primary"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Row 0 -->
    <LinearLayout
        android:id="@+id/budget_0_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/budget_0_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Food"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/budget_0_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="₹0 / ₹0"
                android:textColor="@color/widget_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/budget_0_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/budget_1_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/budget_1_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Transport"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/budget_1_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="₹0 / ₹0"
                android:textColor="@color/widget_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/budget_1_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <TextView
        android:id="@+id/budget_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="@color/widget_text_faint"
        android:textSize="11sp"
        android:visibility="gone" />
</LinearLayout>
