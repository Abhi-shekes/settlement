<?xml version="1.0" encoding="utf-8"?>
<!-- Month Spend widget: total spent this month, trend vs last month, top category. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_card"
    android:padding="@dimen/widget_padding">

    <TextView
        android:id="@+id/month_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This month"
        android:textColor="@color/widget_text_muted"
        android:textSize="12sp"
        android:letterSpacing="0.05"
        android:textAllCaps="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:baselineAligned="false"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/month_spend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0"
            android:textColor="@color/widget_brand"
            android:textSize="28sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/month_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="3dp"
            android:text=""
            android:textColor="@color/widget_text_muted"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/month_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="No spending yet"
        android:textColor="@color/widget_text_primary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textColor="@color/widget_text_faint"
        android:textSize="11sp" />
</LinearLayout>
