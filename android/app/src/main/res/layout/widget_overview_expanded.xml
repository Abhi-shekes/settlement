<?xml version="1.0" encoding="utf-8"?>
<!--
    Finance Overview widget (expanded / large sizes): net worth + monthly spend,
    top category, up to 2 budget progress rows, and quick actions. Uses the
    neutral card surface so budget progress bars read correctly.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_card"
    android:padding="@dimen/widget_padding">

    <!-- Headline figures -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Net worth"
                android:textColor="@color/widget_text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.04"
                android:textAllCaps="true" />
            <TextView
                android:id="@+id/net_worth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="₹0"
                android:textColor="@color/widget_brand"
                android:textSize="24sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spent this month"
                android:textColor="@color/widget_text_muted"
                android:textSize="11sp"
                android:letterSpacing="0.04"
                android:textAllCaps="true" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:baselineAligned="false"
                android:layout_marginTop="2dp">
                <TextView
                    android:id="@+id/month_spend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="24sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/month_delta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="2dp"
                    android:text=""
                    android:textColor="@color/widget_text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/month_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text=""
        android:textColor="@color/widget_text_muted"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/budget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="No budgets set yet"
        android:textColor="@color/widget_text_faint"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Budget row 0 -->
    <LinearLayout
        android:id="@+id/budget_0_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/budget_0_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Food"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/budget_0_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="₹0 / ₹0"
                android:textColor="@color/widget_text_muted"
                android:textSize="12sp" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/budget_0_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <!-- Budget row 1 -->
    <LinearLayout
        android:id="@+id/budget_1_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="10dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/budget_1_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Transport"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/budget_1_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="₹0 / ₹0"
                android:textColor="@color/widget_text_muted"
                android:textSize="12sp" />
        </LinearLayout>
        <ProgressBar
            android:id="@+id/budget_1_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="5dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <!-- Quick actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/btn_add"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:background="@drawable/widget_btn_brand_ripple">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_widget_add"
                android:contentDescription="@string/widget_action_add" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/widget_action_add"
                android:textColor="@color/widget_on_brand"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_assistant"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:background="@drawable/widget_btn_brand_ripple">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_widget_assistant"
                android:contentDescription="@string/widget_action_assistant" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/widget_action_assistant"
                android:textColor="@color/widget_on_brand"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
